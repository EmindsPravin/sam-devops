        dir('websample'){
        git branch: 'main', credentialsId: 'EMPra_git', url: 'https://github.com/EmindsPravin/jenkins-sam.git'
        }
    }
    stage('clone devops'){
        dir('devops'){
        git branch: 'main', credentialsId: 'EMPra_git', url: 'https://github.com/EmindsPravin/sam-devops.git'
