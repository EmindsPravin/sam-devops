//     }
}


    stage("Docker Build and Push"){
        def previousbuild = currentBuild.previousSuccessfulBuild
        def REGISTRY = "mrstester"        
        def REPO = "websample" 
        def JOB_NAME = "test-ppl"


	def old_tag = "${JOB_NAME}-jen-v1.${previousbuild.number}"
	def new_tag = "${JOB_NAME}-jen-dev1.${currentBuild.number}"

        if (previousbuild != null) {
             echo "Previous Successful Build Number: ${previousbuild.number}"
             echo "Last Worked Image: ${REGISTRY}/${REPO}:${old_tag}"
        } else {
             echo "No previous successful build found."
        }
     
        
        def IMAGE = "${REGISTRY}/${REPO}:${new_tag }"
        echo "Current Image: ${IMAGE}"

        sh "sed -i    's/RRR/${REGISTRY}/g' /var/lib/jenkins/workspace/websam-pipe1/devops/websample/deployment.yaml"

        sh "sed -i    's/rrr/${REPO}/g' /var/lib/jenkins/workspace/websam-pipe1/devops/websample/deployment.yaml"

        sh "sed -i    's/ttt/${new_tag}/g' /var/lib/jenkins/workspace/websam-pipe1/devops/websample/deployment.yaml"

        sh "docker build -t ${IMAGE} /var/lib/jenkins/workspace/websam-pipe1/"
        sh "docker push ${IMAGE}"
    }

    stage('Kubectl apply'){
        withCredentials([file(credentialsId: 'k8s-local-M59', variable: 'k8s')]){
        sh 'kubectl --kubeconfig $k8s apply -f /var/lib/jenkins/workspace/websam-pipe1/devops/websample/deployment.yaml '
        }
     }
    
